# ============================
# Base invariants DEV
# ============================
APP_ENV=dev
APP_SLUG=cal
APP_NAME=Calendrier
APP_DEPOT=calendrier
APP_NO=2
APP_HOST=localhost

# ============================
# Ports hôte (dérivés de APP_NO)
# ============================
DEV_DB_PORT=5434
DEV_API_PORT=8003
DEV_VITE_PORT=5175

# ============================
# PostgreSQL (conteneur db)
# ============================
POSTGRES_DB=${APP_SLUG}_pg_db
POSTGRES_USER=${APP_SLUG}_pg_user
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ============================
# Backend Django
# ============================
DJANGO_DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend,vite
FRONT_ORIGIN=http://localhost:${DEV_VITE_PORT}

# ============================
# Frontend Vite
# ============================
VITE_API_BASE=/api
VITE_ADMIN_URL=http://localhost:${DEV_API_PORT}/admin/

# ============================
# Secrets dans .env.local (non versionné)
# ============================
# POSTGRES_PASSWORD=***
# DJANGO_SECRET_KEY=***
# ADMIN_USERNAME=***
# ADMIN_PASSWORD=***
# ADMIN_EMAIL=***
