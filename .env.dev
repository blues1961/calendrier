APP_ENV=dev

APP_NAME=Calendrier
APP_SLUG=cal
APP_DEPOT=calendrier
APP_NO=2
POSTGRES_USER=cal_pg_user
POSTGRES_DB=cal_pg_db

DEV_DB_PORT=5434
DEV_VITE_PORT=5175
DEV_API_PORT=8003

VITE_API_BASE=/api
VITE_SHOW_ADMIN_LINK=false
VITE_ADMIN_URL=/admin/
CONTACT_API_BASE=http://host.docker.internal:8005/api
CONTACT_API_TIMEOUT=5

DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,backend,frontend,0.0.0.0,host.docker.internal
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7
